# Copy to a real environment file (e.g. /etc/foritech/server-readonly.env)
# with 0640 permissions, owner root, group forybg — mirroring
# /etc/foritech/mcp-readonly.env used by the unrelated Diagnostics 3
# service. Never commit the real values.

# Static bearer token accepted alongside OAuth access tokens.
MCP_SERVER_READONLY_BEARER_TOKEN=

# pbkdf2_sha256 hash of the /server/authorize login password, in the form:
# pbkdf2_sha256$<iterations>$<url-safe-base64-salt>$<url-safe-base64-digest>
MCP_SERVER_OAUTH_LOGIN_PASSWORD_HASH=

# Predefined OAuth client id/redirect URI pair allowed to skip PKCE
# discovery via a Client ID Metadata Document (mirrors Diagnostics 3's
# ChatGPT-connector flow). Leave blank to require CIMD-based PKCE for
# every client.
MCP_SERVER_OAUTH_CLIENT_ID=
MCP_SERVER_OAUTH_REDIRECT_URI=

# Local port the HTTP server binds on 127.0.0.1. Must not collide with
# Diagnostics 3 (3110) or any other local service. 3111 was free at the
# time this project was created — re-verify before deploying.
MCP_SERVER_READONLY_PORT=3111
